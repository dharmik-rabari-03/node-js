<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EJS CRUD</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

</head>

<body>

    <div class="container mt-5 d-flex justify-content-center">

        <div class="card  p-4 w-50">

            <h1 class="text-center mb-4">Student List</h1>

            <ul class="mb-3">
                <% studentList.forEach((s)=>{ %>
                    <li class="d-flex justify-content-between align-items-center mb-2">

                        <span>
                            <%= s.name %>
                        </span>
                        <div>

                            <a href="/edit/<%= s.id %>" class="btn btn-outline-warning">
                                Edit
                            </a>


                            <form action="/delete/<%= s.id %>" method="POST" style="display: inline;">
                                <button class=" btn btn-sm btn-danger">Delete</button>
                            </form>
                        </div>

                    </li>
                    <% }) %>
            </ul>

            <div class="text-center">
                <a href="/add" class="btn btn-outline-primary ">Add Student</a>
            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>

</body>

</html>